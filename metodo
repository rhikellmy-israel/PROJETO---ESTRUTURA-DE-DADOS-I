import javax.swing.*;

public class SistemaEscolar {        
    private int total = 0;
    private Alunos[] alunos = new Alunos[60];

    public SistemaEscolar(){
        int opcao;
        do{
            String menu = "1. Cadastrar\n2. Calcular\n3. Exibir\n4. Sair";
            String leitura = JOptionPane.showInputDialog(menu);
            if(leitura == null) break;

            opcao = Integer.parseInt(leitura);

            switch(opcao){
                case 1: cadastrar(); break;
                case 2: calcular(); break;
                case 3: exibir(); break;
            }

        }while(true);
    }

    public void cadastrar(){
        if(total >= 60){
            JOptionPane.showMessageDialog(null, "Lotado");
            return;
        }

        JTextField nome = new JTextField();
        JTextField n1 = new JTextField();
        JTextField n2 = new JTextField();
        JTextField n3 = new JTextField();
        JTextField n4 = new JTextField();
        JTextField n5 = new JTextField();

        Object[] form = {
            "Nome", nome,
            "Nota de Matemática", n1,
            "Nota de Português", n2,
            "Nota de História", n3,
            "Nota de Geografia", n4,
            "Nota de Ciências", n5
        };

        int r = JOptionPane.showConfirmDialog(null, form);

        if(r == JOptionPane.OK_OPTION){
            alunos[total] = new Alunos(
                nome.getText(),
                Double.parseDouble(n1.getText()),
                Double.parseDouble(n2.getText()),
                Double.parseDouble(n3.getText()),
                Double.parseDouble(n4.getText()),
                Double.parseDouble(n5.getText())
            );
            total++;
        }
    }

    public void calcular(){
        for(int i=0;i<total;i++){
            Alunos a = alunos[i];

            double media = (a.getNotaMatematica()+a.getNotaPortugues()+
                            a.getNotaHistoria()+a.getNotaGeografia()+
                            a.getNotaCiencias())/5;

            a.setMedia(media);

        if (aluno.getNotaMatematica() >= 6 && aluno.getNotaPortugues() >= 6 && aluno.getNotaHistoria() >= 6 && aluno.getNotaGeografia() >= 6 && aluno.getNotaCiencias() >= 6){
            Situacao = "Aprovado";
        } else if (aluno.getNotaMatematica() < 6 || aluno.getNotaPortugues() < 6 || aluno.getNotaHistoria() < 6 || aluno.getNotaGeografia() < 6 || aluno.getNotaCiencias() < 6 && Media == 6){ 
            Situacao = "Recuperação";
        } else {
            Situacao = "Reprovado";
        }
        }

        JOptionPane.showMessageDialog(null,"Cálculo realizado!");
    }

    public void exibir(){
        String[] col = {"Nome","Média","Situação"};
        Object[][] dados = new Object[total][3];

        for(int i=0;i<total;i++){
            dados[i][0] = alunos[i].getNome();
            dados[i][1] = alunos[i].getNotaMatematica();
            dados[i][2] = alunos[i].getNotaPortugues();
            dados[i][3] = alunos[i].getNotaHistoria();
            dados[i][4] = alunos[i].getNotaGeografia();
            dados[i][5] = alunos[i].getNotaCiencias();
            dados[i][6] = alunos[i].getMedia();
            dados[i][7] = alunos[i].getSituacao();
        } 

        JTable tabela = new JTable(dados,col);
        JOptionPane.showMessageDialog(null,new JScrollPane(tabela));
    }

    public static void main(String[] args) {
        new SistemaEscolar();
    }
}